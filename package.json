{
  "name": "receptionist-agent-v1",
  "version": "1.0.0",
  "description": "After-Hours AI Receptionist for Urgent Care - MVP",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "USE_MOCKS=true nodemon src/index.js",
    "test": "jest --setupFilesAfterEnv ./tests/setup.js",
    "test:watch": "jest --watch --setupFilesAfterEnv ./tests/setup.js",
    "test:unit": "jest tests/unit --setupFilesAfterEnv ./tests/setup.js",
    "test:integration": "jest tests/integration --setupFilesAfterEnv ./tests/setup.js",
    "test:coverage": "jest --coverage --setupFilesAfterEnv ./tests/setup.js",
    "test:mock": "node scripts/test-mock-flow.js",
    "lint": "eslint src/",
    "validate": "node scripts/validate-env.js",
    "docker:build": "docker build -t receptionist-agent .",
    "docker:run": "docker-compose up",
    "docker:dev": "docker-compose --profile dev up app-dev"
  },
  "keywords": [
    "ai-receptionist",
    "urgent-care",
    "retell-ai",
    "hathr-ai",
    "signalwire",
    "keragon",
    "voice-agent"
  ],
  "author": "Simone",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@signalwire/compatibility-api": "^3.2.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  }
}

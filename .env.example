# ===========================================
# RECEPTIONIST AGENT V1 - ENVIRONMENT CONFIG
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -------------------------------------------
# SERVER CONFIGURATION
# -------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# -------------------------------------------
# MOCK MODE CONFIGURATION
# Set to 'true' to use mock services when real APIs are unavailable
# -------------------------------------------
MOCK_MODE=true

# -------------------------------------------
# RETELL AI CONFIGURATION
# Telephony + voice AI + outbound SMS
# https://www.retellai.com/
# -------------------------------------------
RETELL_API_KEY=your_retell_api_key
RETELL_LLM_ID=your_retell_llm_id
RETELL_AGENT_ID=your_retell_agent_id
RETELL_WEBHOOK_SECRET=your_retell_webhook_secret

# -------------------------------------------
# HATHR.AI CONFIGURATION
# LLM layer for conversation intelligence
# Healthcare-focused AI platform
# -------------------------------------------
HATHR_API_KEY=your_hathr_api_key
HATHR_API_URL=https://api.hathr.ai/v1
HATHR_MODEL_ID=your_hathr_model_id

# -------------------------------------------
# KERAGON CONFIGURATION
# Automation orchestration — 4 workflow webhooks
# See config/keragon-workflow-specs.md for setup
# -------------------------------------------
KERAGON_API_KEY=your_keragon_api_key
KERAGON_WORKSPACE_ID=your_keragon_workspace_id
# Workflow 1: receptionist_call_log (call_ended, call_record, call_analyzed)
KERAGON_WEBHOOK_URL=https://webhooks.us-1.keragon.com/v1/workflows/9f74dcab-6aa2-4615-8798-9a2b41290f7d/rBWs2NzSWYKwNDjU4h0Xb/signal
# Workflow 2: receptionist_emergency_alert (emergency_detected)
KERAGON_EMERGENCY_WEBHOOK_URL=https://webhooks.us-1.keragon.com/v1/workflows/9e1230aa-8f16-472b-8f1c-802d630c6870/MAWIR-EoI_dtStyx90d_D/signal
# Workflow 3: receptionist_sms_events (sms_sent, patient_rating, sms_opt_out, sms_opt_in, sms_freetext_reply)
KERAGON_SMS_WEBHOOK_URL=https://webhooks.us-1.keragon.com/v1/workflows/0fa3ed22-7187-470e-a3ee-db67d0ff0ec9/QDUbX18unW6JbTta1HD8U/signal
# Workflow 4: receptionist_edge_cases (sms_failed, phi_auto_deletion, call_status_update, edge_case)
KERAGON_EDGE_WEBHOOK_URL=https://webhooks.us-1.keragon.com/v1/workflows/2760c73d-8d0f-4a70-a243-0e6cf2195b89/M0QohyDG1wOGlbj3dhDqR/signal

# -------------------------------------------
# GOOGLE CALENDAR CONFIGURATION
# Clinic hours and soft scheduling reference
# -------------------------------------------
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# -------------------------------------------
# CLINIC CONFIGURATION
# -------------------------------------------
CLINIC_NAME="Your Urgent Care Name"
CLINIC_ADDRESS="123 Main St, City, State ZIP"
CLINIC_PHONE=+1XXXXXXXXXX

# Business hours (24hr format, comma-separated)
# Format: DAY:OPEN-CLOSE
CLINIC_HOURS="MON:08:00-20:00,TUE:08:00-20:00,WED:08:00-20:00,THU:08:00-20:00,FRI:08:00-20:00,SAT:09:00-17:00,SUN:10:00-16:00"
CLINIC_TIMEZONE=America/New_York

# -------------------------------------------
# SMS CONFIGURATION
# RetellAI handles outbound SMS. Integration approach (API call vs. agent-triggered)
# is TBD — see src/config/smsProvider.js for the stub to wire when confirmed.
# Set the inbound SMS webhook URL on your Retell number to:
#   POST https://<APP_BASE_URL>/webhook/sms/inbound
# -------------------------------------------
APP_BASE_URL=https://your-domain.com
SMS_ENABLED=true
SMS_FOLLOWUP_DELAY_MINUTES=5

# -------------------------------------------
# SPAM DETECTION THRESHOLDS
# -------------------------------------------
SPAM_SILENCE_THRESHOLD_MS=3000
SPAM_KEYWORD_MATCH_THRESHOLD=2

# -------------------------------------------
# SCHEDULER
# -------------------------------------------
SCHEDULER_ENABLED=true
PHI_RETENTION_DAYS=7

# -------------------------------------------
# SECURITY
# -------------------------------------------
WEBHOOK_SIGNATURE_SECRET=your_webhook_signature_secret
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
